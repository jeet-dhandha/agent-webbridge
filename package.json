{
  "name": "kimi-webbridge-fleet",
  "version": "0.0.1",
  "description": "Kimi WebBridge with multiple Chrome profiles & logins at once — drive several Google accounts simultaneously, not one at a time. Fixes the single connection slot / one-login limit with one daemon per profile + a router on :10086.",
  "type": "module",
  "bin": {
    "kwb": "bin/kwb.mjs"
  },
  "exports": {
    "./profiles": "./src/profiles.mjs",
    "./snss": "./src/snss.mjs",
    "./extension": "./src/extension.mjs",
    "./fleet": "./src/fleet.mjs",
    "./router": "./src/router.mjs"
  },
  "scripts": {
    "kwb": "node ./bin/kwb.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    ".claude-plugin/",
    "SKILL.md",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "kimi",
    "kimi-webbridge",
    "webbridge",
    "moonshot-ai",
    "browser-automation",
    "web-automation",
    "chrome",
    "chrome-profiles",
    "multi-chrome-profile",
    "ai-agent",
    "claude-code",
    "multi-profile",
    "multi-account",
    "multi-login",
    "multiple-accounts",
    "google-accounts",
    "cdp"
  ],
  "license": "MIT",
  "author": "jeet-dhandha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeet-dhandha/kimi-webbridge-fleet.git"
  },
  "homepage": "https://github.com/jeet-dhandha/kimi-webbridge-fleet#readme",
  "bugs": {
    "url": "https://github.com/jeet-dhandha/kimi-webbridge-fleet/issues"
  }
}
